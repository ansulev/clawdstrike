{
  "name": "@clawdstrike/tui",
  "version": "0.1.0",
  "description": "Security-aware orchestration engine for AI coding agents",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "clawdstrike": "./src/cli/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./cli": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist",
    "cli": "bun run ./src/cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
