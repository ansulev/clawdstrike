{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Edit",
          "file_paths": ["*.yaml", "*.yml"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-policy.sh"
          }
        ]
      }
    ]
  }
}
