        "error_code": null,
        "event_type": "remote.file_transfer",
        "cua_action": "file_transfer",
        "decision": "allow",
        "direction": "upload"
      }
    },
    {
      "id": "openclaw_disconnect",
      "description": "CUA disconnect from OpenClaw produces canonical remote.session.disconnect event",
      "query": {
        "source": "openclaw",
        "tool_name": "cua.close",
        "params": {},
