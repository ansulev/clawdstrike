    {
      "id": "parity_violation_detected",
      "description": "Forced parity mismatch fails closed with PRV_PARITY_VIOLATION",
      "query": {
        "type": "parity_check",
        "intent": "input",
        "provider_a": {
          "provider": "openai",
          "provider_input": {
            "tool": "computer_use",
            "action": "click"
          }
        },
        "provider_b": {
          "provider": "claude",
          "provider_input": {
            "tool": "computer",
            "action": "mouse_click"
          }
        },
        "override_canonical_b": {
          "eventType": "remote.session.connect",
          "data": {
            "cuaAction": "click",
            "direction": null
          }
        }
      },
      "expected": {
        "result": "fail",
        "error_code": "PRV_PARITY_VIOLATION"
      }
    },
    {
      "id": "missing_required_field_fails_closed",
      "description": "Missing canonical cuaAction fails closed with PRV_MISSING_REQUIRED_FIELD",
      "query": {
        "provider": "openai",
        "intent": "input",
        "provider_input": {
          "tool": "computer_use",
          "action": "click"
        },
        "override_canonical": {
          "eventType": "input.inject",
          "data": {
            "direction": null
          }
        }
      },
      "expected": {
        "result": "fail",
        "error_code": "PRV_MISSING_REQUIRED_FIELD"
      }
    }
