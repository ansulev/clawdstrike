    {
      "id": "cross_provider_connect_parity_holds",
      "description": "OpenAI and Claude connect actions produce identical parity fields",
      "query": {
        "type": "parity_check",
        "intent": "connect",
        "provider_a": {
          "provider": "openai",
          "provider_input": {
            "tool": "computer_use",
            "action": "navigate",
            "url": "https://example.com"
          }
        },
        "provider_b": {
          "provider": "claude",
          "provider_input": {
            "tool": "computer",
            "action": "navigate",
            "url": "https://example.com"
          }
        }
      },
      "expected": {
        "result": "pass",
        "parity": true
      }
    },
