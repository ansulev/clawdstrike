{
  "name": "@clawdstrike/create-plugin",
  "version": "0.1.0",
  "description": "Scaffold a new ClawdStrike plugin project",
  "type": "module",
  "bin": {
    "create-plugin": "./dist/index.js"
  },
  "main": "./dist/index.js",
