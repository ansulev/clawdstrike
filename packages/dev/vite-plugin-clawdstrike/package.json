{
  "name": "@clawdstrike/vite-plugin-clawdstrike",
  "version": "0.1.0",
  "description": "Vite plugin for ClawdStrike plugin hot module replacement during development",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "clawdstrike",
    "vite",
    "plugin",
    "hmr",
    "security"
  ],
  "author": "Clawdstrike Contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/backbay-labs/clawdstrike.git",
    "directory": "packages/dev/vite-plugin-clawdstrike"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
